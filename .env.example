# Copy to .env.local and fill in. Do not commit .env.local.
# Frontend (Vite) — used when running npm run dev / build

# Backend base URL (no trailing slash). Same as BACKEND_URL in GAS.
# Example: https://livremagiquelabmain-production.up.railway.app
VITE_BACKEND_URL=

# Gemini API key for story/image generation in the browser.
# Example: AIza...
VITE_GEMINI_API_KEY=
